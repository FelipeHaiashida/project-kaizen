# ---------------------------------------------------------------------------
# Kaizen — variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha os valores.
# ---------------------------------------------------------------------------

# Banco de dados (PostgreSQL via Supabase)
# DATABASE_URL usa o pooler (porta 6543); DIRECT_URL usa conexão direta (5432)
DATABASE_URL=
DIRECT_URL=

# NextAuth.js v5
# Gere um segredo com: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (envio de emails de convite)
RESEND_API_KEY=
